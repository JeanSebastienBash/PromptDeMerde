{
  "$comment": "PromptDeMerde.com — pdm-config.schema.json | Synopsis : Schéma JSON Schema Draft 2020-12 du format export/import. | Objectif : Documenter machine les 36 clés pdm_* pour validateurs et mainteneurs (schéma export 1.11.0).",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://promptdemerde.com/schemas/pdm-config.schema.json",
  "title": "PromptDeMerde pdm-config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "type",
    "pdm_provider",
    "pdm_model",
    "pdm_system_prompt",
    "pdm_system_prompt_enabled",
    "pdm_profiles",
    "pdm_language",
    "pdm_theme",
    "pdm_history_count",
    "pdm_clean_history",
    "pdm_workspace",
    "pdm_stt_device_id",
    "pdm_stt_engine",
    "pdm_stt_compute",
    "pdm_context_position",
    "pdm_ollama_url",
    "pdm_llm_thinking_enabled",
    "pdm_llm_thinking_max_chars",
    "pdm_token_ollama",
    "pdm_context_gen_system",
    "pdm_context_gen_user_intent",
    "pdm_context_gen_user_title",
    "pdm_context_inject_header",
    "pdm_context_gen_tag_intent_suffix",
    "pdm_context_gen_forced_tag_system_suffix",
    "pdm_context_gen_retry_system_suffix",
    "pdm_context_gen_retry_user_suffix",
    "pdm_active_profile",
    "pdm_project",
    "pdm_context_profile_line_template",
    "pdm_context_gen_max_tokens",
    "pdm_context_gen_temperature",
    "pdm_context_gen_retry_temperature",
    "pdm_context_gen_max_retries",
    "pdm_context_gen_json_schema",
    "pdm_audio_blobs",
    "pdm_workspace_ui"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "type": {
      "const": "pdm-config"
    },
    "exportedAt": {
      "type": "string",
      "format": "date-time"
    },
    "pdm_provider": {
      "type": "string"
    },
    "pdm_model": {
      "type": "string"
    },
    "pdm_system_prompt": {
      "type": "string",
      "minLength": 1
    },
    "pdm_system_prompt_enabled": {
      "type": "boolean"
    },
    "pdm_llm_thinking_enabled": {
      "type": "boolean"
    },
    "pdm_llm_thinking_max_chars": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100000
    },
    "pdm_language": {
      "enum": [
        "fr",
        "en"
      ]
    },
    "pdm_theme": {
      "enum": [
        "light",
        "day",
        "orange-day",
        "red-day",
        "gray-day",
        "yellow-day",
        "fuchsia-day",
        "ocean-day",
        "forest-day",
        "cyber-day",
        "rose-day",
        "terminal-day",
        "dark",
        "orange",
        "red",
        "gray",
        "yellow",
        "fuchsia",
        "ocean",
        "forest",
        "cyber",
        "rose",
        "terminal"
      ]
    },
    "pdm_context_position": {
      "enum": [
        "after_system",
        "before_system"
      ]
    },
    "pdm_stt_engine": {
      "enum": [
        "vosk-mini",
        "vosk-maxi",
        "whisper-mini",
        "whisper-maxi",
        "parakeet"
      ]
    },
    "pdm_stt_compute": {
      "enum": [
        "cpu",
        "gpu"
      ]
    },
    "pdm_stt_device_id": {
      "type": "string"
    },
    "pdm_ollama_url": {
      "type": "string",
      "format": "uri"
    },
    "pdm_token_ollama": {
      "type": "string"
    },
    "pdm_context_gen_system": {
      "type": "string",
      "minLength": 1
    },
    "pdm_context_gen_user_intent": {
      "type": "string",
      "minLength": 1
    },
    "pdm_context_gen_user_title": {
      "type": "string",
      "minLength": 1
    },
    "pdm_context_inject_header": {
      "type": "string",
      "minLength": 1
    },
    "pdm_context_gen_tag_intent_suffix": {
      "type": "string",
      "minLength": 1
    },
    "pdm_context_gen_forced_tag_system_suffix": {
      "type": "string",
      "minLength": 1
    },
    "pdm_context_gen_retry_system_suffix": {
      "type": "string",
      "minLength": 1
    },
    "pdm_context_gen_retry_user_suffix": {
      "type": "string",
      "minLength": 1
    },
    "pdm_active_profile": {
      "type": "string",
      "minLength": 1
    },
    "pdm_project": {
      "type": "object",
      "required": ["platform_url", "name", "url", "vitrine_url"],
      "properties": {
        "platform_url": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 },
        "vitrine_url": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "pdm_context_profile_line_template": {
      "type": "string",
      "minLength": 1
    },
    "pdm_context_gen_max_tokens": {
      "type": "integer",
      "minimum": 1,
      "maximum": 8192
    },
    "pdm_context_gen_temperature": {
      "type": "number",
      "minimum": 0,
      "maximum": 2
    },
    "pdm_context_gen_retry_temperature": {
      "type": "number",
      "minimum": 0,
      "maximum": 2
    },
    "pdm_context_gen_max_retries": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10
    },
    "pdm_context_gen_json_schema": {
      "type": "object"
    },
    "pdm_history_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "pdm_profiles": {
      "type": "array",
      "maxItems": 999,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "tag",
          "prompt",
          "active"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "tag": {
            "type": "string",
            "pattern": "^[A-Z][a-zA-Z0-9]*$"
          },
          "prompt": {
            "type": "string"
          },
          "active": {
            "type": "boolean"
          },
          "origin": {
            "type": "object",
            "additionalProperties": false,
            "required": ["method"],
            "properties": {
              "method": {
                "enum": ["ai_intent", "ai_title", "manual", "profile_bundle"]
              },
              "generatedAt": {
                "type": "string",
                "format": "date-time"
              },
              "createdAt": {
                "type": "string",
                "format": "date-time"
              },
              "provider": {
                "type": "string"
              },
              "model": {
                "type": "string"
              },
              "systemPrompt": {
                "type": "string"
              },
              "userPrompt": {
                "type": "string"
              },
              "sourceFile": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "pdm_workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input",
        "output",
        "thinking",
        "savedAt",
        "contextPanelOpen",
        "inputSource",
        "audioFileName",
        "audioFileSize",
        "audioMimeType",
        "audioLastModified",
        "audioRef"
      ],
      "properties": {
        "input": {
          "type": "string"
        },
        "output": {
          "type": "string"
        },
        "thinking": {
          "type": "string"
        },
        "savedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "contextPanelOpen": {
          "type": "boolean"
        },
        "inputSource": {
          "enum": ["manual", "audio-file", "audio-dictation"]
        },
        "audioFileName": {
          "type": ["string", "null"]
        },
        "audioFileSize": {
          "type": ["number", "null"]
        },
        "audioMimeType": {
          "type": ["string", "null"]
        },
        "audioLastModified": {
          "type": ["number", "null"]
        },
        "audioRef": {
          "type": ["string", "null"]
        }
      }
    },
    "pdm_clean_history": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "at", "input"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "at": { "type": "string", "format": "date-time" },
          "input": { "type": "string" },
          "output": { "type": "string" },
          "thinking": { "type": "string" },
          "systemPrompt": { "type": "string" },
          "systemPromptEffective": { "type": "string" },
          "contextPosition": { "enum": ["after_system", "before_system"] },
          "activeContexts": { "type": "array" },
          "usage": { "type": ["object", "null"] },
          "duration_ms": { "type": "number" },
          "provider": { "type": "string" },
          "model": { "type": "string" },
          "inputSource": { "enum": ["manual", "audio-file", "audio-dictation"] },
          "audioFileName": { "type": ["string", "null"] },
          "audioFileSize": { "type": ["number", "null"] },
          "audioMimeType": { "type": ["string", "null"] },
          "audioLastModified": { "type": ["number", "null"] },
          "audioRef": { "type": ["string", "null"] }
        }
      }
    },
    "pdm_audio_blobs": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "pdm_workspace_ui": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity", "brand", "texts"],
      "properties": {
        "identity": {
          "type": "object",
          "additionalProperties": false,
          "required": ["username", "hostname", "usernameAlt"],
          "properties": {
            "username": { "type": "string", "minLength": 1 },
            "hostname": { "type": "string", "minLength": 1 },
            "usernameAlt": { "type": "string" }
          }
        },
        "brand": {
          "description": "Logo nav plateforme fixe (PromptDeMerde.com). Valeurs en lecture seule à l'export ; toute personnalisation est ignorée.",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "firstWord",
            "secondWord",
            "extension",
            "showExtension",
            "firstWordClass",
            "secondWordClass",
            "extensionClass"
          ],
          "properties": {
            "firstWord": { "type": "string" },
            "secondWord": { "type": "string" },
            "extension": { "type": "string" },
            "showExtension": { "type": "boolean" },
            "firstWordClass": { "type": "string" },
            "secondWordClass": { "type": "string" },
            "extensionClass": { "type": "string" }
          }
        },
        "texts": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
