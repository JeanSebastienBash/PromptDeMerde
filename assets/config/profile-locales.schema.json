{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://promptdemerde.com/schemas/profile-locales.json",
  "title": "PromptDeMerde profile locales index",
  "type": "object",
  "required": ["version", "type", "defaultLocale", "locales"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "type": { "const": "pdm-profile-locales" },
    "defaultLocale": { "type": "string", "pattern": "^[a-z]{2}$" },
    "locales": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z]{2}$" }
    }
  }
}
